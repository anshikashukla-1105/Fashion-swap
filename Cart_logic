using UnityEngine;

public class anglechecking : MonoBehaviour
{
    [SerializeField] Transform target;
    [SerializeField] float range = 5f;
    [SerializeField] float speed = 5f;

    bool targetWasInRange = false;

    void Update()
    {
        float moveX = Input.GetAxis("Horizontal"); // A/D
        float moveZ = Input.GetAxis("Vertical");   // W/S

        Vector3 movement = new Vector3(moveX, 0f, moveZ);
        transform.Translate(movement * speed * Time.deltaTime, Space.World);

        var directionToTarget=(target.position -transform.position).normalized;
        var dotProduct=Vector3.Dot(transform.forward,directionToTarget);
        var angle =Mathf.Acos(dotProduct);
        Debug.LogFormat("The angle bwt my forward direction and {0} is {1:F1}",target.name,angle *Mathf.Rad2Deg);        
    }
}

